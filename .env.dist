# Copy this file to .env and customise for your site.
# Used by both `docker compose` (image builds) and `make install` (local dev).

# --- Image names/tags ---
BACKEND_IMAGE=
FRONTEND_IMAGE=

# --- Versions ---
PLONE_VERSION=6.1.1
VOLTO_VERSION=18.23.0

# --- Custom runtime base images (optional) ---
# Leave empty to use the official plone/server-prod-config and plone/frontend-prod-config images.
BACKEND_PROD_CONFIG_IMAGE=
FRONTEND_PROD_CONFIG_IMAGE=

# --- Extra backend packages (optional) ---
# Comma-separated pip specifiers. Must be compatible with Plone constraints.
# Example: BACKEND_ADD_PACKAGES=collective.easyform==4.2.0
BACKEND_ADD_PACKAGES=

# --- Extra frontend packages/addons (optional) ---
# ADD_PACKAGES: comma-separated npm specifiers added to package.json.
# ADD_ADDONS:   comma-separated addon names registered in volto.config.js.
# Example: FRONTEND_ADD_PACKAGES=@collective/volto-form-block@3.9.0
#          FRONTEND_ADD_ADDONS=@collective/volto-form-block
FRONTEND_ADD_PACKAGES=
FRONTEND_ADD_ADDONS=

# SET_THEME: Volto theme package name. Example: FRONTEND_SET_THEME=@plone/volto-theme
FRONTEND_SET_THEME=

# ADD_MRSDEVELOPER: JSON object of mrs-developer entries for git-sourced packages.
# Example: FRONTEND_ADD_MRSDEVELOPER={"my-addon":{"url":"git@github.com:org/my-addon.git","https":"https://github.com/org/my-addon.git","tag":"1.0.0"}}
FRONTEND_ADD_MRSDEVELOPER=

# ADD_PNPM_WORKSPACE: comma-separated glob patterns appended to pnpm-workspace.yaml.
# Example: FRONTEND_ADD_PNPM_WORKSPACE=packages/my-addon
FRONTEND_ADD_PNPM_WORKSPACE=

# --- Database ---
DB_NAME=plone
DB_HOST=db
DB_PORT=5432
DB_PASSWORD=NwUNXCDsHSsd
